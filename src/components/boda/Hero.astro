---
import MagicDust from "./MagicDust";
import Stars from "./Stars";
import AnimatedNames from "./AnimatedNames";
import Constellation from "./Constellation";
import Rings from "./Rings";
import CountDownDate from "./CountDownDate";

const fechaBoda = "2026-10-02T21:00:00";
---

<section class="relative min-h-screen flex items-center justify-center text-center px-6 bg-ivory-50">

  <!-- textura suave tipo papel -->
  <div class="absolute inset-0 opacity-20 bg-[url('/textures/paper.jpg')] bg-cover"></div>

  <div class="relative z-10 max-w-3xl">


    <!-- <div class="w-32 h-[1px] bg-gold-500 mx-auto my-10"></div> -->

    <p class="text-lg text-earth-700 max-w-xl mx-auto leading-relaxed">
      Bajo el cielo abierto de nuestra hacienda,
      celebraremos el inicio de nuestra historia eterna.
    </p>

    <div class="flex w-full items-center justify-center p-5 rounded-full bg-navy-900">

        <CountDownDate client:load date={fechaBoda} />
    </div>

  </div>
</section>
