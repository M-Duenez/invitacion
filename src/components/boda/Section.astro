---
const { variant = "dark" } = Astro.props;

const styles = {
  dark: "bg-navy-950 text-wedding-ivory",
  navy: "bg-navy-900 text-wedding-ivory",
  gold: "bg-navy-500 text-navy-950"
};
---

<section class={`py-32 px-6 text-center ${styles[variant]}`}>
  <div class="max-w-4xl mx-auto">
    <slot />
  </div>
</section>